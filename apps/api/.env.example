# Copiar este ficheiro para .env e preencher com valores reais.
# .env nunca vai para o git (está no .gitignore).

# Porta onde a API escuta
PORT=3000

# Ligação à BD Postgres local.
# Formato: postgresql://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mini_trello

# Segredo usado para assinar tokens JWT.
# Em DEV qualquer string serve. NUNCA usar este valor em servidor remoto.
JWT_SECRET=troca-isto-por-uma-string-aleatoria-longa

# Tempo de validade do token (formato suportado pelo jsonwebtoken: "1h", "30m", "7d", ...)
JWT_EXPIRES_IN=1m
